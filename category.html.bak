<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Проєкти — Central Architects</title>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: sans-serif; background-color: #121212; color: #fff; padding-top: 60px; }
        .site-header { position: fixed; top: 0; width: 100%; height: 60px; background: #000; display: flex; align-items: center; justify-content: center; gap: 30px; z-index: 1000; }
        .site-header a { color: #fff; text-decoration: none; text-transform: uppercase; font-size: 14px; }
        .site-header a.active { color: #0073aa; }
        .container { max-width: 1200px; margin: 40px auto; padding: 20px; }
        h1 { text-align: center; margin-bottom: 40px; text-transform: uppercase; }
        .projects-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(350px, 1fr)); gap: 30px; }
        .project-card { background: #1e1e1e; border-radius: 8px; overflow: hidden; text-decoration: none; color: #fff; transition: 0.3s; }
        .project-card:hover { transform: translateY(-5px); }
        .project-card img { width: 100%; height: 250px; object-fit: cover; }
        .project-info { padding: 20px; }
    </style>
</head>
<body>

    <header class="site-header">
        <a href="index.html">Головна</a>
        <a href="categories.html" class="active">Наші проекти</a>
    </header>

    <div class="container">
        <h1 id="category-title">Завантаження...</h1>
        <div class="projects-grid" id="projects-grid"></div>
    </div>

    <script>
        const extensions = ['.jpg', '.JPG', '.png', '.PNG', '.webp', '.WEBP', '.jpeg', '.JPEG'];

        function setCardImage(imgElement, folderPath) {
            const basePaths = [
                `./${folderPath}/interior_001`,
                `./${folderPath}/image_001`
            ];
            
            let pathIndex = 0;
            let extIndex = 0;

            const tryNext = () => {
                if (pathIndex >= basePaths.length) return;

                if (extIndex >= extensions.length) {
                    extIndex = 0;
                    pathIndex++;
                    tryNext();
                    return;
                }

                const testUrl = basePaths[pathIndex] + extensions[extIndex];
                const tempImg = new Image();
                tempImg.onload = () => { imgElement.src = testUrl; };
                tempImg.onerror = () => { extIndex++; tryNext(); };
                tempImg.src = testUrl;
            };
            tryNext();
        }

        document.addEventListener("DOMContentLoaded", async () => {
            const urlParams = new URLSearchParams(window.location.search);
            const categoryType = urlParams.get('type');
            
            if (!categoryType) {
                document.getElementById('category-title').textContent = "Категорію не знайдено";
                return;
            }

            try {
                const response = await fetch('./projects.json');
                const data = await response.json();
                const projects = data[categoryType] || [];
                
                const titlesMap = {
                    'interiors': 'Інтер\'єри',
                    'public_interiors': 'Громадські інтер\'єри',
                    'architecture': 'Архітектура',
                    'public_architecture': 'Громадська архітектура'
                };

                document.getElementById('category-title').textContent = titlesMap[categoryType] || 'Проєкти';
                const grid = document.getElementById('projects-grid');
                grid.innerHTML = '';

                projects.forEach(project => {
                    const card = document.createElement('a');
                    card.href = `project.html?type=${categoryType}&id=${project.id}`;
                    card.className = 'project-card';
                    
                    const img = document.createElement('img');
                    img.alt = project.title;
                    setCardImage(img, project.folder);

                    const info = document.createElement('div');
                    info.className = 'project-info';
                    info.innerHTML = `<h3>${project.title}</h3>`;

                    card.appendChild(img);
                    card.appendChild(info);
                    grid.appendChild(card);
                });
            } catch (err) {
                console.error("Помилка:", err);
            }
        });
    </script>
</body>
</html>